# ==============================================
# EJEMPLO DE VARIABLES DE ENTORNO
# ==============================================
# Copiar este archivo a .env y configurar con valores reales
# NUNCA subir el archivo .env a repositorios públicos

# Database Configuration
DB_USERNAME=root
DB_PASSWORD=tu_password_mysql_aqui

# JWT Configuration
# IMPORTANTE: Usar un secret de al menos 32 caracteres
# Generar con: openssl rand -base64 32
JWT_SECRET=ServiFarma2026_ClaveSegura#42!ConMasDe32Caracteres
JWT_EXPIRATION=86400000

# Nota: Para cargar estas variables en desarrollo:
# 1. En IDE (IntelliJ/Eclipse): Configurar en Run Configuration
# 2. En línea de comandos: export NOMBRE_VARIABLE=valor (Linux/Mac)
#                          set NOMBRE_VARIABLE=valor (Windows CMD)
#                          $env:NOMBRE_VARIABLE="valor" (Windows PowerShell)
